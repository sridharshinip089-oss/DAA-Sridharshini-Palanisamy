<!-- nodes -->

<circle cx="80" cy="60" r="20" class="node"/>
<text x="73" y="66" class="label">0</text>

<circle cx="220" cy="50" r="20" class="node"/>
<text x="213" y="56" class="label">1</text>

<circle cx="390" cy="60" r="20" class="node"/>
<text x="383" y="66" class="label">2</text>

<circle cx="120" cy="220" r="20" class="node"/>
<text x="113" y="226" class="label">3</text>

<circle cx="370" cy="180" r="20" class="node"/>
<text x="363" y="186" class="label">4</text>

<circle cx="250" cy="310" r="20" class="node"/>
<text x="243" y="316" class="label">5</text>

<circle cx="530" cy="170" r="20" class="node"/>
<text x="523" y="176" class="label">6</text>

</svg>

</div>

</div>

<div class="card">

<h2>Python Code</h2>

<pre id="code">
Paste your complete Python code here.
</pre>

</div>

<div class="card">

<center>

<button onclick="runProgram()">
Run MST Algorithms
</button>

</center>

<div id="output" class="output"></div>

</div>

</div>

<script>

document.getElementById("code").textContent=`import heapq

