<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>N-Queens Visualizer</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#05070d;
color:white;
}

.container{
width:95%;
max-width:1300px;
margin:auto;
padding:30px;
}

h1{
text-align:center;
color:#4FC3F7;
margin-bottom:25px;
}

.card{
background:#111827;
padding:25px;
border-radius:15px;
margin-bottom:25px;
border:1px solid #1E40AF;
box-shadow:0 0 15px rgba(0,100,255,.15);
}

input{
width:100%;
padding:14px;
margin-top:12px;
background:#1F2937;
border:none;
color:white;
font-size:18px;
border-radius:10px;
outline:none;
}

button{
margin-top:20px;
padding:13px 30px;
font-size:18px;
background:#2563EB;
border:none;
color:white;
border-radius:10px;
cursor:pointer;
transition:.3s;
}

button:hover{
background:#1D4ED8;
transform:scale(1.05);
}

.result{
margin-top:20px;
font-size:20px;
line-height:1.8;
}

.highlight{
color:#4ADE80;
font-weight:bold;
}

.board{
display:inline-block;
margin:20px;
padding:15px;
background:#0F172A;
border-radius:12px;
}

table{
border-collapse:collapse;
}

td{
width:45px;
height:45px;
text-align:center;
font-size:28px;
border:1px solid #334155;
}

.white{
background:#E2E8F0;
color:black;
}

.black{
background:#475569;
}

.solutionTitle{
text-align:center;
margin-bottom:10px;
color:#FBBF24;
font-weight:bold;
}

#boards{
margin-top:30px;
display:flex;
flex-wrap:wrap;
justify-content:center;
}

.footer{
text-align:center;
margin-top:25px;
color:#94A3B8;
}

</style>

</head>

<body>

<div class="container">

<h1>♛ N-Queens Problem Visualizer</h1>

<div class="card">

<label>Enter Number of Queens (N)</label>

<input
type="number"
id="n"
value="4"
min="4"
max="10">

<button onclick="run()">Solve</button>

<div class="result">

<div>
Total Solutions :
<span class="highlight" id="solutions"></span>
</div>

<div>
Backtracks :
<span class="highlight" id="backtracks"></span>
</div>

</div>

</div>

<div class="card">

<h2 style="text-align:center;color:#60A5FA;">
Solutions
</h2>

<div id="boards"></div>

</div>

<div class="footer">
N-Queens using Backtracking Algorithm
</div>

</div>

<script>

function isSafe(board,row,col){

for(let prev=0;prev<row;prev++){

let placed=board[prev];

if(placed===col)
return false;

if(Math.abs(prev-row)===Math.abs(placed-col))
return false;

}

return true;

}

function solveQueens(n){

let board=new Array(n).fill(-1);

let solutions=[];

let backtracks=0;

function backtrack(row){

if(row===n){

solutions.push([...board]);

return;

}

for(let col=0;col<n;col++){

if(isSafe(board,row,col)){

board[row]=col;

backtrack(row+1);

board[row]=-1;

backtracks++;

}

}

}

backtrack(0);

return{
solutions,
backtracks
};

}

function createBoard(solution,n,index){

let html="<div class='board'>";

html+="<div class='solutionTitle'>Solution "+index+"</div>";

html+="<table>";

for(let r=0;r<n;r++){

html+="<tr>";

for(let c=0;c<n;c++){

let color=((r+c)%2==0)?"white":"black";

if(solution[r]==c){

html+="<td class='"+color+"'>♛</td>";

}

else{

html+="<td class='"+color+"'></td>";

}

}

html+="</tr>";

}

html+="</table>";

html+="</div>";

return html;

}

function run(){

let n=parseInt(document.getElementById("n").value);

let result=solveQueens(n);

document.getElementById("solutions").innerHTML=result.solutions.length;

document.getElementById("backtracks").innerHTML=result.backtracks;

let boards=document.getElementById("boards");

boards.innerHTML="";

if(n<=6){

result.solutions.forEach((sol,index)=>{

boards.innerHTML+=createBoard(sol,n,index+1);

});

}

else{

boards.innerHTML="<h3 style='color:#FBBF24'>Displaying all boards for N > 6 is disabled because there are many solutions.<br>Total Solutions = "+result.solutions.length+"</h3>";

}

}

run();

</script>

</body>
</html>
