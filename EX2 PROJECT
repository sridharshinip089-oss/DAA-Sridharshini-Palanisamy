<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>String Matching Algorithms</title>

  <style>
    * {
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      margin: 0;
      padding: 30px;
      background: #f4f6f9;
      color: #222;
    }

    .container {
      max-width: 1100px;
      margin: auto;
      background: white;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.12);
    }

    h1 {
      text-align: center;
      color: #1f4e79;
    }

    h2 {
      color: #1f4e79;
      margin-top: 30px;
    }

    label {
      display: block;
      margin-top: 15px;
      font-weight: bold;
    }

    textarea,
    input {
      width: 100%;
      padding: 12px;
      margin-top: 7px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 16px;
    }

    textarea {
      resize: vertical;
      min-height: 90px;
    }

    button {
      margin-top: 20px;
      margin-right: 10px;
      padding: 12px 18px;
      border: none;
      border-radius: 6px;
      background: #1f4e79;
      color: white;
      font-size: 16px;
      cursor: pointer;
    }

    button:hover {
      background: #163a5b;
    }

    .result-box {
      margin-top: 20px;
      padding: 15px;
      background: #eaf4ff;
      border-left: 5px solid #1f4e79;
      border-radius: 5px;
      line-height: 1.7;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    th,
    td {
      border: 1px solid #ccc;
      padding: 12px;
      text-align: center;
    }

    th {
      background: #1f4e79;
      color: white;
    }

    tr:nth-child(even) {
      background: #f2f2f2;
    }

    .highlight {
      color: #1f4e79;
      font-weight: bold;
    }

    .note {
      color: #555;
      font-size: 14px;
      margin-top: 12px;
    }
  </style>
</head>

<body>
  <div class="container">
    <h1>String Matching Algorithm Comparison</h1>

    <h2>Search Pattern in Text</h2>

    <label for="textInput">Enter Text:</label>
    <textarea id="textInput">AABAACAADAABAABA</textarea>

    <label for="patternInput">Enter Pattern:</label>
    <input type="text" id="patternInput" value="AABA" />

    <button onclick="runSearch()">Run Search</button>
    <button onclick="runPerformance()">Performance Comparison</button>

    <div class="result-box" id="resultBox">
      Enter text and pattern, then click “Run Search”.
    </div>

    <h2>Performance Comparison</h2>

    <table>
      <thead>
        <tr>
          <th>Pattern</th>
          <th>Naive Comparisons</th>
          <th>KMP Comparisons</th>
          <th>Rabin-Karp Comparisons</th>
        </tr>
      </thead>
      <tbody id="performanceTable">
        <tr>
          <td colspan="4">Click “Performance Comparison” to generate results.</td>
        </tr>
      </tbody>
    </table>

    <p class="note">
      Naive Search checks every possible position. KMP uses the LPS array.
      Rabin-Karp uses hash values to find possible matches.
    </p>
  </div>

  <script>
    function naiveSearch(text, pattern) {
      const n = text.length;
      const m = pattern.length;
      let matches = [];
      let comparisons = 0;

      for (let i = 0; i <= n - m; i++) {
        let j = 0;

        while (j < m) {
          comparisons++;

          if (text[i + j] !== pattern[j]) {
            break;
          }

          j++;
        }

        if (j === m) {
          matches.push(i);
        }
      }

      return { matches, comparisons };
    }

    function computeLPS(pattern) {
      const m = pattern.length;
      let lps = new Array(m).fill(0);

      let length = 0;
      let i = 1;

      while (i < m) {
        if (pattern[i] === pattern[length]) {
          length++;
          lps[i] = length;
          i++;
        } else {
          if (length !== 0) {
            length = lps[length - 1];
          } else {
            lps[i] = 0;
            i++;
          }
        }
      }

      return lps;
    }

    function kmpSearch(text, pattern) {
      const n = text.length;
      const m = pattern.length;

      let lps = computeLPS(pattern);
      let matches = [];
      let comparisons = 0;

      let i = 0;
      let j = 0;

      while (i < n) {
        comparisons++;

        if (pattern[j] === text[i]) {
          i++;
          j++;
        }

        if (j === m) {
          matches.push(i - j);
          j = lps[j - 1];
        } else if (i < n && pattern[j] !== text[i]) {
          if (j !== 0) {
            j = lps[j - 1];
          } else {
            i++;
          }
        }
      }

      return { matches, comparisons };
    }

    function rabinKarp(text, pattern, q = 101) {
      const n = text.length;
      const m = pattern.length;
      const d = 256;

      let h = 1;
      for (let i = 0; i < m - 1; i++) {
        h = (h * d) % q;
      }

      let pHash = 0;
      let tHash = 0;
      let matches = [];
      let comparisons = 0;

      for (let i = 0; i < m; i++) {
        pHash = (d * pHash + pattern.charCodeAt(i)) % q;
        tHash = (d * tHash + text.charCodeAt(i)) % q;
      }

      for (let s = 0; s <= n - m; s++) {
        if (pHash === tHash) {
          let k;

          for (k = 0; k < m; k++) {
            comparisons++;

            if (text[s + k] !== pattern[k]) {
              break;
            }
          }

          if (k === m) {
            matches.push(s);
          }
        }

        if (s < n - m) {
          tHash =
            (d * (tHash - text.charCodeAt(s) * h) +
              text.charCodeAt(s + m)) %
            q;

          if (tHash < 0) {
            tHash += q;
          }
        }
      }

      return { matches, comparisons };
    }

    function runSearch() {
      const text = document.getElementById("textInput").value;
      const pattern = document.getElementById("patternInput").value;

      if (text === "" || pattern === "") {
        document.getElementById("resultBox").innerHTML =
          "<strong>Please enter both text and pattern.</strong>";
        return;
      }

      if (pattern.length > text.length) {
        document.getElementById("resultBox").innerHTML =
          "<strong>Pattern length should not be greater than text length.</strong>";
        return;
      }

      const naive = naiveSearch(text, pattern);
      const kmp = kmpSearch(text, pattern);
      const rk = rabinKarp(text, pattern);

      document.getElementById("resultBox").innerHTML = `
        <strong>Text:</strong> ${text}<br>
        <strong>Pattern:</strong> ${pattern}<br><br>

        <span class="highlight">Naive Search</span><br>
        Matches at: [${naive.matches.join(", ")}]<br>
        Comparisons: ${naive.comparisons}<br><br>

        <span class="highlight">KMP Search</span><br>
        Matches at: [${kmp.matches.join(", ")}]<br>
        Comparisons: ${kmp.comparisons}<br><br>

        <span class="highlight">Rabin-Karp Search</span><br>
        Matches at: [${rk.matches.join(", ")}]<br>
        Comparisons: ${rk.comparisons}
      `;
    }

    function generateRandomText(length) {
      const characters = "ABCD";
      let text = "";

      for (let i = 0; i < length; i++) {
        text += characters[Math.floor(Math.random() * characters.length)];
      }

      return text;
    }

    function runPerformance() {
      const textLarge = generateRandomText(10000);
      const patterns = ["AB", "ABCD", "ABCDAB", "ABCDABCD"];

      const table = document.getElementById("performanceTable");
      table.innerHTML = "";

      patterns.forEach((pattern) => {
        const naive = naiveSearch(textLarge, pattern);
        const kmp = kmpSearch(textLarge, pattern);
        const rk = rabinKarp(textLarge, pattern);

        table.innerHTML += `
          <tr>
            <td>${pattern}</td>
            <td>${naive.comparisons}</td>
            <td>${kmp.comparisons}</td>
            <td>${rk.comparisons}</td>
          </tr>
        `;
      });
    }
  </script>
</body>
</html>
```
